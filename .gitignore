# --- Virtual environments (keep OUT of git) ---
.venv/
.venv-*/
venv/
env/

# --- Python cache / bytecode ---
__pycache__/
*.py[cod]
*$py.class

# --- Packaging / build artifacts ---
build/
dist/
*.egg-info/
.eggs/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Logs ---
*.log

# --- Test / tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.coverage
htmlcov/

# --- IDE/editor files ---
.vscode/
.idea/
*.iml

# --- OS cruft ---
.DS_Store
Thumbs.db

# --- Environment variables / secrets ---
.env
.env.*

# --- Ultralytics / YOLO common outputs ---
runs/
wandb/

# Optional: ignore exported models / weights (can be big)
# If you WANT to keep trained weights in git, comment these out.
*.pt
*.pth
*.onnx
*.engine
